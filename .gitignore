# Python
__pycache__/
*.py[cod]
*.so

# Virtual environments
.venv/
venv/

# IDEs
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Python tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Build artifacts
build/
dist/
*.egg-info/

# Logs
*.log

# Runtime caches
runtime/cache/
runtime/tmp/

# Temporary files
*.tmp
*.bak
*~


# Generated runtime artifacts
runtime/index/*
runtime/reports/*
runtime/analysis/*
runtime/preview/*
runtime/approval/*
runtime/apply/*

# Preserve runtime directory structure
!runtime/index/.gitkeep
!runtime/reports/.gitkeep
!runtime/analysis/.gitkeep
!runtime/preview/.gitkeep
!runtime/approval/.gitkeep
!runtime/apply/.gitkeep

# v2 transaction workspaces (system-drive runtime evidence)
runtime/staging/transactions/

# Local commissioning and Music Assistant snapshots
runtime/fixtures/
runtime/ma-db-*/

# KINTYRE generated runtime data
runtime/staging/
runtime/replacement/
runtime/music-assistant/

# Keep directory structure
!runtime/.gitkeep
!runtime/**/.gitkeep
